# Copy to deploy/fleet/.env and fill in.  (deploy/fleet/.env is gitignored.)

# REQUIRED — a fixed Fernet key so the panel survives restarts (otherwise it crashes on restart
# decrypting its own fleet identity). Generate one:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SWARMKIT_CONTROL_PLANE_SECRET_KEY=

# OPTIONAL — a model key so instances can actually run topologies (and thus emit traces/metrics).
# Enrollment, serving, and the dashboards work without it; runs need it.
OPENROUTER_API_KEY=
