# Vedanta Advisor — Environment Variables
# Copy to .env and fill in values: cp .env.sample .env

# === Required ===

# OpenRouter API key — used for all LLM calls (advisor, graph builder, verifier)
# Get one at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key

# === Paths (defaults work if running from examples/vedanta-advisor/) ===

# ChromaDB storage — 98K+ scripture verses
VEDANTA_CHROMADB_DIR=./knowledge/chromadb

# GBrain storage — wisdom graph (auto-created by init-gbrain.sh)
# Note: GBrain uses ~/.gbrain by default. Override with this var.
VEDANTA_BRAIN_DIR=./knowledge/brain

# Notes directory — agent output
VEDANTA_NOTES_DIR=./knowledge/notes

# Datasets directory — fetched GitHub repos
VEDANTA_DATASETS_DIR=./knowledge/datasets

# === Optional ===

# Override the default model for all agents
# SWARMKIT_MODEL=anthropic/claude-sonnet-4

# Override the provider (default: openrouter)
# SWARMKIT_PROVIDER=openrouter

# Verbose logging — shows tool calls and model interactions
# SWARMKIT_VERBOSE=1

# IndicTrans2 model override (default: ai4bharat/indictrans2-en-indic-1B)
# INDICTRANS_MODEL=ai4bharat/indictrans2-en-indic-1B
