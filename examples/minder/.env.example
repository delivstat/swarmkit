# Copy this to .env and fill in your values.
# Most of these are configured automatically via the onboarding webapp at http://minder.local
# Only OPENROUTER_API_KEY is needed to get started (if no local GPU).

# Telegram bot (optional at startup — configure via webapp)
MINDER_TELEGRAM_TOKEN=

# Cloud AI (required if no local GPU)
OPENROUTER_API_KEY=

# Camera defaults (auto-detected by webapp, override here if needed)
MINDER_SUBNET=192.168.0
MINDER_CAM_USER=admin
MINDER_CAM_PASS=admin123

# Home Assistant (configured via webapp)
HA_TOKEN=

# Vision VLM for on-demand open-scene questions ("is the gate open").
# Object presence (person/car/animal) uses YOLO, not the VLM.
# Default llava-phi3 (3.8B): doesn't hallucinate people (moondream did), runs on
# CPU/RAM (num_gpu=0) kept warm, ~5s/query warm. minicpm-v (8B) and qwen2.5vl (3B)
# are too slow on CPU here; use qwen2.5vl:3b on a dedicated-GPU appliance.
MINDER_VISION_MODEL=llava-phi3
# VLM device: 0 = CPU/RAM (default, keeps the GPU for reasoning). >0 = GPU layers.
MINDER_VISION_NUM_GPU=0

# Frigate genai event-description enrichment (runs the VLM on every detection).
# OFF by default — it contends for VRAM 24/7 and doesn't drive alerts. Enable
# only on a dedicated-GPU appliance, paired with a Frigate-recommended VLM
# (qwen2.5vl:3b or qwen3-vl:4b), not moondream.
MINDER_GENAI=off
