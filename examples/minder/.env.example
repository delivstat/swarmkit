# Copy this to .env and fill in your values.
# Most of these are configured automatically via the onboarding webapp at http://minder.local
# Only OPENROUTER_API_KEY is needed to get started (if no local GPU).

# Telegram bot (optional at startup — configure via webapp)
MINDER_TELEGRAM_TOKEN=

# Cloud AI (required if no local GPU). Also powers Scenario Studio custom-detector
# auto-labeling (one-time setup only — the trained detector then runs fully local).
OPENROUTER_API_KEY=
# Vision model used for auto-labeling AND, when MINDER_DESCRIBE_PROVIDER=openrouter,
# for the "what it sees" descriptions (cheap + strong at scene detail).
MINDER_CLOUD_VISION_MODEL=google/gemini-2.5-flash

# Two vision model layers (design/two-layer-vision-models.md):
# LAYER 1 — per-alert enrichment in the Frigate poller (high frequency). Keep this
# local/cheap. "ollama" (default, zero-cloud) or "openrouter" (cloud, uses
# MINDER_CLOUD_VISION_MODEL). Falls back to local on cloud failure.
MINDER_DESCRIBE_PROVIDER=ollama
# LAYER 2 — interactive queries + complex questions ("what is the person doing",
# "is there danger"): the capable model that reads AND judges the scene. "ollama"
# (default) or "openrouter" + a multimodal model. Kimi K2.6 is multimodal (reasons
# + sees in one call). Needs OPENROUTER_API_KEY; falls back to the local VLM.
#   MINDER_QUERY_PROVIDER=openrouter
#   MINDER_QUERY_MODEL=moonshotai/kimi-k2.6
MINDER_QUERY_PROVIDER=ollama
MINDER_QUERY_MODEL=

# Reasoning/router model. Default is the local qwen2.5:3b on Ollama. To test a
# higher-quality cloud model (e.g. Kimi K2.6 via OpenRouter), set provider+model
# (needs OPENROUTER_API_KEY). This routes agent reasoning off-box — a quality
# benchmark, not the zero-cloud shipping default.
#   MINDER_REASONING_PROVIDER=openrouter
#   MINDER_REASONING_MODEL=moonshotai/kimi-k2.6

# Camera defaults (auto-detected by webapp, override here if needed)
MINDER_SUBNET=192.168.0
MINDER_CAM_USER=admin
MINDER_CAM_PASS=admin123

# Home Assistant (configured via webapp)
HA_TOKEN=

# Vision VLM for on-demand open-scene questions ("is the gate open").
# Object presence (person/car/animal) uses YOLO, not the VLM.
# Default llava-phi3 (3.8B): doesn't hallucinate people (moondream did), runs on
# CPU/RAM (num_gpu=0) kept warm, ~5s/query warm. minicpm-v (8B) and qwen2.5vl (3B)
# are too slow on CPU here; use qwen2.5vl:3b on a dedicated-GPU appliance.
MINDER_VISION_MODEL=llava-phi3
# VLM device: 0 = CPU/RAM (default, keeps the GPU for reasoning). >0 = GPU layers.
MINDER_VISION_NUM_GPU=0

# Frigate genai event-description enrichment (runs the VLM on every detection).
# OFF by default — it contends for VRAM 24/7 and doesn't drive alerts. Enable
# only on a dedicated-GPU appliance, paired with a Frigate-recommended VLM
# (qwen2.5vl:3b or qwen3-vl:4b), not moondream.
MINDER_GENAI=off
