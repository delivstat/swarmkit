{
  "name": "@swael/schema",
  "version": "0.0.1",
  "description": "Swael JSON Schemas + TypeScript validator.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schemas/*": "./schemas/*"
  },
  "files": [
    "dist",
    "schemas",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-schemas.mjs",
    "lint": "biome check src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^22.7.0",
    "quicktype-core": "^23.2.6",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "yaml": "^2.8.3"
  }
}
