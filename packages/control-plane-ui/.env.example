# Base URL of the swarmkit-control-plane API (the panel API). Defaults to same-origin when unset.
NEXT_PUBLIC_CONTROL_PLANE_API=http://localhost:8800

# OIDC login (optional). Set NEXT_PUBLIC_OIDC_AUTHORITY to require sign-in; leave unset to run open.
# Configure your IdP with a SPA/public client and a redirect URI of this UI's origin.
# NEXT_PUBLIC_OIDC_AUTHORITY=https://your-idp.example.com
# NEXT_PUBLIC_OIDC_CLIENT_ID=swarmkit-fleet-ui
# NEXT_PUBLIC_OIDC_SCOPE=openid profile email
# Some IdPs (e.g. Auth0) need an explicit API audience matching the panel's --oidc-audience:
# NEXT_PUBLIC_OIDC_AUDIENCE=swarmkit-control-plane
